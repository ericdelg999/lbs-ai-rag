# OpenAI API key (required for embeddings + answer generation)
OPENAI_API_KEY=your-openai-api-key-here

# Tesseract OCR path (required for PDF text extraction with OCR fallback)
# Default (Windows): C:\Users\<user>\AppData\Local\Programs\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=

# Poppler bin path (required for pdf2image OCR conversion)
# Default (Windows): C:\Users\<user>\Downloads\Release-24.08.0-0\poppler-24.08.0\Library\bin
POPPLER_PATH=
